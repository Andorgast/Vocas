<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Vocas</title>
    <script type="importmap"></script>
    <script src="https://cdn.tailwindcss.com"></script>
</head>
<body>
    <header>
        <p><a class="nav-link text-dark" asp-area="" asp-controller="Home" asp-action="Index">Home</a></p>
    </header>
    <div class="container">
        <main role="main" class="pb-3">
            @RenderBody()
        </main>
    </div>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
